{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "schemaVersion",
    "profiles",
    "features"
  ],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "1"
    },
    "profiles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "features": {
      "type": "array",
      "minItems": 8,
      "items": {
        "type": "object",
        "required": [
          "feature",
          "direct",
          "light",
          "bifrost",
          "agentgateway"
        ],
        "additionalProperties": false,
        "properties": {
          "feature": {
            "type": "string"
          },
          "direct": {
            "$ref": "#/$defs/status"
          },
          "light": {
            "$ref": "#/$defs/status"
          },
          "bifrost": {
            "$ref": "#/$defs/status"
          },
          "agentgateway": {
            "$ref": "#/$defs/status"
          }
        }
      }
    }
  },
  "$defs": {
    "status": {
      "type": "object",
      "required": [
        "status",
        "reason"
      ],
      "additionalProperties": false,
      "properties": {
        "status": {
          "enum": [
            "equivalent",
            "light-only-required",
            "comparator-only",
            "unsupported",
            "not-applicable"
          ]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "enabled": {
          "type": "boolean"
        }
      }
    }
  }
}

