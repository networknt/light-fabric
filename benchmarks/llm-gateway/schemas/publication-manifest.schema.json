{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "schemaVersion",
    "hostId",
    "environment",
    "sequence",
    "minimumGatewayVersion",
    "resources",
    "rootDigest"
  ],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "1"
    },
    "hostId": {
      "type": "string"
    },
    "environment": {
      "type": "string"
    },
    "sequence": {
      "type": "integer",
      "minimum": 1
    },
    "minimumGatewayVersion": {
      "type": "string"
    },
    "resources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "resourceType",
          "resourceId",
          "resourceVersion",
          "digest"
        ],
        "additionalProperties": false,
        "properties": {
          "resourceType": {
            "type": "string"
          },
          "resourceId": {
            "type": "string"
          },
          "resourceVersion": {
            "type": "string"
          },
          "digest": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          },
          "tombstone": {
            "type": "boolean"
          }
        }
      }
    },
    "rootDigest": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  }
}

